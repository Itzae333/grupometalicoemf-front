{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/nexus-portal"
      }
    }
  ],
  "routes": [
    
    { "src": "/(.*\\.(js|css|png|jpg|ico|svg|json))", "dest": "/$1" },
  
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}